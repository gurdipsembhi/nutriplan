PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://your_db_user:your_db_password@cluster.mongodb.net/nutriplan?retryWrites=true&w=majority
OPENAI_API_KEY=sk-proj-your_key_here
CLIENT_URL=http://localhost:5173
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4000

# Auth
JWT_SECRET=changeme_min32chars_replace_in_production
JWT_EXPIRES_IN=7d
SESSION_SECRET=changeme_session_secret_replace_in_production

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
